---
import type { SiteMeta } from "@/types";
import { siteConfig } from "@/site-config";
import { getAlternateLinks, localeInfo, resolveSiteLocale } from "@/i18n/utils";
import "../styles/global.css";
import "../styles/shiki-twoslash.css";

type Props = SiteMeta;

const { title, description, ogImage, articleDate, locale: metaLocale } = Astro.props;

const titleSeparator = "•";
const siteTitle = `${title} ${titleSeparator} ${siteConfig.title}`;
const locale = resolveSiteLocale(metaLocale ?? Astro.currentLocale);
const activeLocaleInfo = localeInfo[locale];
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(ogImage ? ogImage : "/social-card.png", Astro.url).href;
const alternateLinks = getAlternateLinks(Astro.url.pathname).map((alternate) => ({
  ...alternate,
  href: new URL(alternate.href, Astro.site).href,
}));
const alternateOgLocales = alternateLinks
  .filter((alternate): alternate is (typeof alternateLinks)[number] & { locale: keyof typeof localeInfo } => {
    return alternate.locale !== "x-default" && alternate.locale !== locale;
  })
  .map((alternate) => localeInfo[alternate.locale].ogLocale);
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, shrink-to-fit=no" />
<meta http-equiv="X-UA-Compatible" content="IE=edge" />
<title>{siteTitle}</title>

<!-- Icons / Favicon -->
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" href="/icon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<meta name="title" content={siteTitle} />
<meta name="description" content={description} />
<meta name="author" content={siteConfig.author} />

<!-- Theme Colour -->
<meta name="theme-color" content="" />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={articleDate ? "article" : "website"} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:site_name" content={siteConfig.title} />
<meta property="og:locale" content={activeLocaleInfo.ogLocale} />
{alternateOgLocales.map((ogLocale) => <meta property="og:locale:alternate" content={ogLocale} />)}
<meta property="og:image" content={socialImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{
  articleDate && (
    <>
      <meta property="article:author" content={siteConfig.author} />
      <meta property="article:published_time" content={articleDate} />
    </>
  )
}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImageURL} />

<!-- Sitemap -->
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- RSS auto-discovery -->
<link rel="alternate" type="application/rss+xml" title={siteConfig.title} href="/rss.xml" />
{alternateLinks.map((alternate) => <link rel="alternate" hreflang={alternate.hrefLang} href={alternate.href} />)}

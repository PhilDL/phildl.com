---
import type { HTMLAttributes } from "astro/types";
import { getFormattedDate } from "@/utils";
import { resolveSiteLocale } from "@/i18n/utils";

type Props = HTMLAttributes<"time"> & {
  date: Date;
  dateTimeOptions?: Intl.DateTimeFormatOptions;
};

const { date, dateTimeOptions, ...attrs } = Astro.props;
const locale = resolveSiteLocale(Astro.currentLocale);

const postDate = getFormattedDate(date, dateTimeOptions, locale);
---

<time datetime={date.toISOString()} {...attrs}>
  {postDate}
</time>

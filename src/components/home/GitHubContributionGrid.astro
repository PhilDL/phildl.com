---
import type { SiteLocale } from "@/content/locale";
import { localeInfo } from "@/i18n/utils";
import type { GithubContributionCalendar, GithubContributionDay } from "@/utils/githubActivity";

interface Props {
  calendar: GithubContributionCalendar | null;
  locale: SiteLocale;
  title: string;
  summary: string;
  emptyMessage: string;
  lessLabel: string;
  moreLabel: string;
}

const { calendar, locale, title, summary, emptyMessage, lessLabel, moreLabel } = Astro.props;

const CELL_SIZE = 11;
const CELL_GAP = 3;
const dateLocale = localeInfo[locale].dateLocale;
const weekdayMarkers = locale === "fr" ? ["", "Lun", "", "Mer", "", "Ven", ""] : ["", "Mon", "", "Wed", "", "Fri", ""];
const allDays = calendar ? calendar.weeks.flatMap((week) => week.days) : [];
const graphWidth = calendar ? calendar.weeks.length * CELL_SIZE + (calendar.weeks.length - 1) * CELL_GAP : 0;
const monthLabels = calendar
  ? getMonthLabels(
      calendar.weeks.map((week) => week.firstDay),
      dateLocale,
    )
  : [];

const GITHUB_COLOR_TO_LEVEL: Record<string, number> = {
  "#ebedf0": 0,
  "#9be9a8": 1,
  "#40c463": 2,
  "#30a14e": 3,
  "#216e39": 4,
};

function getIntensityLevel(color: string): number {
  return GITHUB_COLOR_TO_LEVEL[color] ?? 0;
}

const maxLevel = allDays.reduce((max, day) => Math.max(max, getIntensityLevel(day.color)), 0);

function getMonthLabels(weekFirstDays: Array<string>, localeValue: string) {
  const labels: Array<{ label: string; left: number }> = [];
  const seenMonths = new Set<string>();

  weekFirstDays.forEach((weekFirstDay, index) => {
    const weekStart = parseIsoDate(weekFirstDay);
    const firstOfMonth = Array.from({ length: 7 }, (_, offset) => addUtcDays(weekStart, offset)).find(
      (date) => date.getUTCDate() === 1,
    );
    const labelDate = firstOfMonth ?? (index === 0 ? weekStart : null);

    if (!labelDate) return;

    const key = `${labelDate.getUTCFullYear()}-${labelDate.getUTCMonth()}`;
    if (seenMonths.has(key)) return;

    seenMonths.add(key);
    labels.push({
      label: labelDate.toLocaleDateString(localeValue, { month: "short", timeZone: "UTC" }),
      left: index * (CELL_SIZE + CELL_GAP),
    });
  });

  return labels;
}

function formatContributionLabel(day: GithubContributionDay) {
  const formattedDate = parseIsoDate(day.date).toLocaleDateString(dateLocale, {
    day: "numeric",
    month: "short",
    year: "numeric",
    timeZone: "UTC",
  });

  if (locale === "fr") {
    return `${day.contributionCount} contribution${day.contributionCount > 1 ? "s" : ""} le ${formattedDate}`;
  }

  return `${day.contributionCount} contribution${day.contributionCount === 1 ? "" : "s"} on ${formattedDate}`;
}

function parseIsoDate(value: string) {
  return new Date(`${value}T00:00:00.000Z`);
}

function addUtcDays(date: Date, days: number) {
  const nextDate = new Date(date);
  nextDate.setUTCDate(nextDate.getUTCDate() + days);
  return nextDate;
}
---

<section class="mt-6">
  <div class="mb-4 flex flex-col gap-1">
    <h2 class="title font-serif text-xl">{title}</h2>
    <p class="text-textColor/70 text-sm">{summary}</p>
  </div>
  {
    calendar ? (
      <div>
        <div class="overflow-x-auto pb-1">
          <div class="inline-grid min-w-fit grid-cols-[auto_1fr] gap-x-3">
            <div class="pt-5">
              <div class="text-textColor/50 grid grid-rows-7 gap-[3px] text-[11px] leading-[11px]">
                {weekdayMarkers.map((label) => (
                  <span class="h-[11px]">{label}</span>
                ))}
              </div>
            </div>
            <div class="min-w-fit">
              <div
                class="text-textColor/50 relative mb-[7px] h-4 text-[11px] leading-none"
                style={`width: ${graphWidth}px;`}
              >
                {monthLabels.map((month) => (
                  <span class="absolute top-0 whitespace-nowrap" style={`left: ${month.left}px;`}>
                    {month.label}
                  </span>
                ))}
              </div>
              <div class="grid grid-flow-col grid-rows-7 gap-[3px]" style={`width: ${graphWidth}px;`}>
                {allDays.map((day) => (
                  <div
                    aria-label={formatContributionLabel(day)}
                    class={`contrib-level-${getIntensityLevel(day.color)} h-[11px] w-[11px]`}
                    role="img"
                    title={formatContributionLabel(day)}
                  />
                ))}
              </div>
            </div>
          </div>
        </div>
        {maxLevel > 0 && (
          <div class="text-textColor/50 mt-3 flex items-center justify-end gap-1.5 text-[11px]">
            <span>{lessLabel}</span>
            {[0, 1, 2, 3, 4].map((level) => (
              <span class={`contrib-level-${level} h-[11px] w-[11px]`} />
            ))}
            <span>{moreLabel}</span>
          </div>
        )}
      </div>
    ) : (
      <p class="text-textColor/70 text-sm">{emptyMessage}</p>
    )
  }
</section>

<style>
  .contrib-level-0 {
    background-color: hsl(var(--theme-text) / 0.06);
  }
  .contrib-level-1 {
    background-color: hsl(var(--theme-accent) / 0.25);
  }
  .contrib-level-2 {
    background-color: hsl(var(--theme-accent) / 0.5);
  }
  .contrib-level-3 {
    background-color: hsl(var(--theme-accent) / 0.75);
  }
  .contrib-level-4 {
    background-color: hsl(var(--theme-accent) / 1);
  }
</style>

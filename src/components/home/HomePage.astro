---
import type { SiteLocale } from "@/content/locale";

import PostPreview from "@/components/blog/PostPreview";
import CurrentlyWorkingOn from "@/components/home/CurrentlyWorkingOn";
import GitHubContributionGrid from "@/components/home/GitHubContributionGrid";
import SocialList from "@/components/SocialList";
import { getCv, getCvFeaturedProjectsFromEntry, getProjectPrimaryLink, getProjects } from "@/content/queries";
import PageLayout from "@/layouts/Base";
import { homePageCopy } from "@/i18n/utils";
import { getGithubActivity } from "@/utils/githubActivity";
import { buildWorkingOnProjects } from "@/utils/githubProjectRegistry";
import { getAllPosts, sortMDByDate } from "@/utils";

interface Props {
  locale: SiteLocale;
}

const { locale } = Astro.props;

const MAX_POSTS = 10;
const copy = homePageCopy[locale];
const [cv, localizedProjects, githubActivity] = await Promise.all([
  getCv(locale),
  getProjects(locale),
  getGithubActivity(),
]);
const featuredProjects = (await getCvFeaturedProjectsFromEntry(cv)).slice(0, 3);
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);
const workingOnProjects = buildWorkingOnProjects(githubActivity.recentRepositories, localizedProjects);

const meta = {
  title: copy.metaTitle,
  description: copy.metaDescription,
  locale,
};
---

<PageLayout meta={meta}>
  <section>
    <h1 class="title mb-6 font-serif">{copy.heroTitle}</h1>
    <p class="mb-2">{copy.heroIntro}</p>
    <p class="mb-4">{cv.data.basics.summary}</p>
    <SocialList />
  </section>
  <CurrentlyWorkingOn
    emptyMessage={copy.workingOnEmpty}
    fallbackDescription={copy.workingOnFallbackDescription}
    items={workingOnProjects}
    locale={locale}
    title={copy.workingOnTitle}
  />
  <GitHubContributionGrid
    calendar={githubActivity.contributionCalendar}
    emptyMessage={copy.contributionsEmpty}
    lessLabel={copy.contributionsLegendLess}
    locale={locale}
    moreLabel={copy.contributionsLegendMore}
    summary={copy.contributionsSummary(githubActivity.contributionCalendar?.totalContributions ?? 0)}
    title={""}
  />
  <section class="mt-16">
    <h2 class="title mb-4 font-serif text-xl">{copy.projectsTitle}</h2>
    <ul class="space-y-4 sm:space-y-2">
      {
        featuredProjects.map((project) => {
          const href = getProjectPrimaryLink(project);

          return (
            <li class="inline-block sm:mt-2">
              {href ? (
                <a href={href} target="_blank" rel="noopener noreferrer" class="cactus-link mr-1 inline-block">
                  {project.data.title}
                </a>
              ) : (
                <span class="mr-1 inline-block font-medium">{project.data.title}</span>
              )}
              <span class="mr-2">:</span> {project.data.description}
            </li>
          );
        })
      }
    </ul>
  </section>
  <section aria-label={copy.postsTitle} class="mt-16">
    <h2 class="title mb-4 font-serif text-xl">{copy.postsTitle}</h2>
    <ul class="space-y-4 sm:space-y-2">
      {
        allPostsByDate.map((p) => (
          <li class="flex flex-col gap-x-2 sm:flex-row">
            <PostPreview post={p} />
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>

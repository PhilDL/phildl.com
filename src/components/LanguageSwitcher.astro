---
import { getLanguageSwitcherLinks, localeInfo, resolveSiteLocale } from "@/i18n/utils";

const url = new URL(Astro.request.url);
const locale = resolveSiteLocale(Astro.currentLocale);
const links = getLanguageSwitcherLinks(url, locale);
---

<nav aria-label={locale === "fr" ? "Changer de langue" : "Switch language"} class="ms-4 flex items-center text-sm">
  {
    links.map((link, i) => (
      <>
        {i > 0 && <span class="text-textColor/40 mx-1">/</span>}
        {link.isCurrent ? (
          <span class="text-accent-2 font-semibold" aria-current="true" title={link.title}>
            {link.label}
          </span>
        ) : (
          <a href={link.href} class="cactus-link" hreflang={localeInfo[link.locale].htmlLang} title={link.title}>
            {link.label}
          </a>
        )}
      </>
    ))
  }
</nav>

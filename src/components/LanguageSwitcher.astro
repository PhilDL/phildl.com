---
import { resolveSiteLocale } from "@/i18n/utils";
import { getLanguageSwitcherLinks } from "@/i18n/utils";

const url = new URL(Astro.request.url);
const locale = resolveSiteLocale(Astro.currentLocale);
const links = getLanguageSwitcherLinks(url.pathname, locale);
---

<nav
  aria-label={locale === "fr" ? "Changer de langue" : "Switch language"}
  class="border-accent/30 ms-4 flex items-center rounded-full border px-1 py-1 text-xs"
>
  {
    links.map((link) =>
      link.isCurrent ? (
        <span
          class="bg-accent text-bgColor rounded-full px-2 py-1 font-semibold"
          aria-current="true"
          title={link.title}
        >
          {link.label}
        </span>
      ) : (
        <a href={link.href} class="text-accent px-2 py-1 sm:hover:underline" hreflang={link.locale} title={link.title}>
          {link.label}
        </a>
      ),
    )
  }
</nav>

---
import { getLanguageSwitcherLinks, localeInfo, resolveSiteLocale } from "@/i18n/utils";

const url = new URL(Astro.request.url);
const locale = resolveSiteLocale(Astro.currentLocale);
const links = getLanguageSwitcherLinks(url, locale);
---

<nav
  aria-label={locale === "fr" ? "Changer de langue" : "Switch language"}
  class="text-md ms-auto mr-2 flex h-9 items-center gap-1"
>
  {
    links.map((link, i) => (
      <>
        {i > 0 && <span class="text-textColor/30 mx-0.5">/</span>}
        {link.isCurrent ? (
          <span class="text-textColor/50 font-medium" aria-current="true" title={link.title}>
            {link.label}
          </span>
        ) : (
          <a
            href={link.href}
            class="hover:text-accent transition-colors"
            hreflang={localeInfo[link.locale].htmlLang}
            title={link.title}
          >
            {link.label}
          </a>
        )}
      </>
    ))
  }
</nav>

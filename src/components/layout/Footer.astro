---
import { siteConfig } from "@/site-config";
import { getNavigationLinks, resolveSiteLocale } from "@/i18n/utils";

const year = new Date().getFullYear();
const locale = resolveSiteLocale(Astro.currentLocale);
const menuLinks = getNavigationLinks(locale);
---

<footer
  class="relative mt-auto flex w-full flex-col items-center justify-center gap-y-2 pt-20 pb-4 text-center align-top text-gray-500 sm:flex-row sm:justify-between sm:text-xs"
>
  <div class="me-0 sm:me-4">
    Copyright &copy; {year}{" "}
    {siteConfig.author}
  </div>
  <nav aria-label="More on this site" class="flex gap-x-2 sm:gap-x-0 sm:divide-x sm:divide-gray-500">
    {
      menuLinks.map((link) => (
        <a href={link.path} class="sm:hover:text-textColor px-4 py-2 sm:px-2 sm:py-0 sm:hover:underline">
          {link.title}
        </a>
      ))
    }
  </nav>
</footer>

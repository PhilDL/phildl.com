---
import PageLayout from "@/layouts/Base";
import PostPreview from "@/components/blog/PostPreview";
import SocialList from "@/components/SocialList";
import { getAllPosts, sortMDByDate } from "@/utils";
import { getFeaturedProjects, getProjectPrimaryLink } from "@/content/queries";

const MAX_POSTS = 10;
const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS);
const featuredProjects = (await getFeaturedProjects()).slice(0, 3);
---

<PageLayout meta={{ title: "Home" }}>
  <section>
    <h1 class="title mb-6 font-serif">My organized chaos.</h1>
    <p class="mb-4">
      Hi 👋, I am Philippe L'ATTENTION, senior software engeneer born in Réunion Island 🇷🇪. Here you will find
      technical gibberish, thoughts, discoveries.
    </p>
    <SocialList />
  </section>
  <section class="mt-16">
    <h2 class="title mb-4 font-serif text-xl">Projects and public work</h2>
    <ul class="space-y-4 sm:space-y-2">
      {
        featuredProjects.map((project) => {
          const href = getProjectPrimaryLink(project);

          return (
            <li class="inline-block sm:mt-2">
              {href ? (
                <a href={href} target="_blank" rel="noopener noreferrer" class="cactus-link mr-1 inline-block">
                  {project.data.title}
                </a>
              ) : (
                <span class="mr-1 inline-block font-medium">{project.data.title}</span>
              )}
              <span class="mr-2">:</span> {project.data.description}
            </li>
          );
        })
      }
    </ul>
  </section>
  <section aria-label="Blog post list" class="mt-16">
    <h2 class="title mb-4 font-serif text-xl">Posts</h2>
    <ul class="space-y-4 sm:space-y-2">
      {
        allPostsByDate.map((p) => (
          <li class="flex flex-col gap-x-2 sm:flex-row">
            <PostPreview post={p} />
          </li>
        ))
      }
    </ul>
  </section>
</PageLayout>

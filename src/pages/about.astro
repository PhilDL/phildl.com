---
import { Image } from "astro:assets";

import FormattedDate from "@/components/FormattedDate";
import {
  getClientProjects,
  getCv,
  getEducation,
  getExperiences,
  getFeaturedOpenSourceProjects,
  getFeaturedProductProjects,
  getProjectPrimaryLink,
} from "@/content/queries";
import PageLayout from "@/layouts/Base";
import { aboutPageCopy, getLocalizedUrl, resolveSiteLocale } from "@/i18n/utils";
import aboutImg from "@/assets/about.jpg";

const locale = resolveSiteLocale(Astro.currentLocale);
const copy = aboutPageCopy[locale];
const cv = await getCv(locale);
const featuredProjects = (await getFeaturedProductProjects(locale)).slice(0, 4);
const openSourceProjects = (await getFeaturedOpenSourceProjects(locale)).slice(0, 4);
const experiences = await getExperiences(locale);
const education = await getEducation(locale);
const clientProjects = (await getClientProjects(locale)).slice(0, 4);

const meta = {
  title: copy.metaTitle,
  description: cv.data.basics.summary,
};

const cvPdfHref = getLocalizedUrl(locale, "cv/philippe-lattention.pdf");
const stripProtocol = (value: string) => value.replace(/^https?:\/\//, "").replace(/\/$/, "");
---

<PageLayout meta={meta}>
  <div class="space-y-16">
    <section class="grid gap-8 md:grid-cols-[minmax(0,1fr)_16rem] md:items-start">
      <div class="max-w-prose space-y-5">
        <h1 class="title">{copy.headline}</h1>
        <p class="text-lg font-medium">{cv.data.basics.headline}</p>
        <p>{cv.data.basics.summary}</p>
        <p>
          {cv.data.basics.location ? `📍 ${copy.locationPrefix} ${cv.data.basics.location}. ` : ""}
          {copy.focusSentence}
        </p>
        <div class="space-y-1 text-sm">
          <p>
            <span class="font-medium">{copy.availabilityLabel}:</span>
            {cv.data.availability.details}
          </p>
          <p>
            <a class="cactus-link font-medium" href={cvPdfHref} download>
              {copy.downloadPdfLabel}
            </a>
          </p>
          {
            cv.data.basics.website && (
              <p>
                <span class="font-medium">{copy.websiteLabel}:</span>{" "}
                <a class="cactus-link" href={cv.data.basics.website}>
                  {stripProtocol(cv.data.basics.website)}
                </a>
              </p>
            )
          }
          {
            cv.data.basics.email && (
              <p>
                <span class="font-medium">{copy.emailLabel}:</span>{" "}
                <a class="cactus-link" href={`mailto:${cv.data.basics.email}`}>
                  {cv.data.basics.email}
                </a>
              </p>
            )
          }
          {
            cv.data.basics.profiles.map((profile) => (
              <p>
                <span class="font-medium">{profile.label}:</span>{" "}
                <a class="cactus-link" href={profile.href} target="_blank" rel="noopener noreferrer">
                  {stripProtocol(profile.href)}
                </a>
              </p>
            ))
          }
        </div>
      </div>
      <div class="flex justify-center md:justify-end">
        <Image
          src={aboutImg}
          alt={copy.profileImageAlt}
          loading="eager"
          fetchpriority="high"
          class="h-56 w-56 object-cover"
        />
      </div>
    </section>

    <section class="max-w-prose space-y-4">
      <h2 class="title text-xl">{copy.focusAreasTitle}</h2>
      <ul class="space-y-2">
        {
          cv.data.focusAreas.map((item: string) => (
            <li class="before:text-accent relative pl-5 before:absolute before:left-0 before:content-['#']">{item}</li>
          ))
        }
      </ul>
    </section>

    <section class="max-w-prose space-y-4">
      <h2 class="title text-xl">{copy.coreStackTitle}</h2>
      <div class="space-y-4">
        {
          cv.data.skillGroups.map((group: (typeof cv.data.skillGroups)[number]) => (
            <div>
              <h3 class="text-accent font-medium">{group.name}</h3>
              <p class="mt-1 text-sm leading-7">{group.items.join(" · ")}</p>
            </div>
          ))
        }
      </div>
    </section>

    {
      cv.data.languages.length > 0 && (
        <section class="max-w-prose space-y-4">
          <h2 class="title text-xl">{copy.languagesTitle}</h2>
          <p class="text-sm leading-7">
            {cv.data.languages.map((item) => `${item.name}${item.level ? ` · ${item.level}` : ""}`).join(" · ")}
          </p>
        </section>
      )
    }

    <section class="max-w-prose space-y-6">
      <h2 class="title text-xl">{copy.experienceTitle}</h2>
      <div class="divide-textColor/20 divide-y divide-dashed">
        {
          experiences.map((entry, i) => (
            <article class:list={[i === 0 ? "pb-6" : "py-6"]}>
              <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
                <div>
                  <h3 class="font-medium">{entry.data.role}</h3>
                  <p class="text-accent text-sm">{entry.data.company}</p>
                </div>
                <p class="text-sm opacity-70">
                  <FormattedDate date={entry.data.startDate} dateTimeOptions={{ month: "short", year: "numeric" }} />
                  {" — "}
                  {entry.data.endDate ? (
                    <FormattedDate date={entry.data.endDate} dateTimeOptions={{ month: "short", year: "numeric" }} />
                  ) : (
                    copy.presentLabel
                  )}
                </p>
              </div>
              <p class="mt-3">{entry.data.summary}</p>
              {(entry.data.achievements?.length ?? 0) > 0 && (
                <ul class="mt-3 list-inside list-disc space-y-1 text-sm">
                  {(entry.data.achievements ?? []).map((achievement: string) => (
                    <li>{achievement}</li>
                  ))}
                </ul>
              )}
              {(entry.data.detailGroups?.length ?? 0) > 0 && (
                <ul class="mt-4 list-disc space-y-4 pl-5">
                  {(entry.data.detailGroups ?? []).map((group) => (
                    <li>
                      <p class="font-medium">{group.title}</p>
                      {group.summary && <p class="mt-1 text-sm">{group.summary}</p>}
                      {(group.achievements?.length ?? 0) > 0 && (
                        <ul class="mt-2 list-inside list-disc space-y-1 text-sm">
                          {(group.achievements ?? []).map((achievement: string) => (
                            <li>{achievement}</li>
                          ))}
                        </ul>
                      )}
                      {(group.items?.length ?? 0) > 0 && (
                        <ul class="mt-2 list-disc space-y-3 pl-5">
                          {(group.items ?? []).map((item) => (
                            <li>
                              <p class="text-sm font-medium">{item.title}</p>
                              {item.summary && <p class="mt-1 text-sm">{item.summary}</p>}
                              {(item.achievements?.length ?? 0) > 0 && (
                                <ul class="mt-2 list-inside list-disc space-y-1 text-sm">
                                  {(item.achievements ?? []).map((achievement: string) => (
                                    <li>{achievement}</li>
                                  ))}
                                </ul>
                              )}
                              {(item.technologies?.length ?? 0) > 0 && (
                                <p class="mt-2 text-sm opacity-70">{(item.technologies ?? []).join(" · ")}</p>
                              )}
                            </li>
                          ))}
                        </ul>
                      )}
                      {(group.technologies?.length ?? 0) > 0 && (
                        <p class="mt-2 text-sm opacity-70">{(group.technologies ?? []).join(" · ")}</p>
                      )}
                    </li>
                  ))}
                </ul>
              )}
              {(entry.data.technologies?.length ?? 0) > 0 && (
                <p class="mt-3 text-sm opacity-70">{(entry.data.technologies ?? []).join(" · ")}</p>
              )}
            </article>
          ))
        }
      </div>
    </section>

    <section class="max-w-prose space-y-6">
      <h2 class="title text-xl">{copy.selectedProjectsTitle}</h2>
      <ul class="space-y-4">
        {
          featuredProjects.map((project) => {
            const href = getProjectPrimaryLink(project);

            return (
              <li>
                <h3 class="font-medium">
                  {href ? (
                    <a class="cactus-link" href={href} target="_blank" rel="noopener noreferrer">
                      {project.data.title}
                    </a>
                  ) : (
                    project.data.title
                  )}
                </h3>
                <p class="mt-1 text-sm">{project.data.description}</p>
                <p class="mt-1 text-sm opacity-70">{project.data.technologies.join(" · ")}</p>
              </li>
            );
          })
        }
      </ul>
    </section>

    {
      openSourceProjects.length > 0 && (
        <section class="max-w-prose space-y-6">
          <h2 class="title text-xl">{copy.openSourceTitle}</h2>
          <ul class="space-y-4">
            {openSourceProjects.map((project) => {
              const href = getProjectPrimaryLink(project);

              return (
                <li>
                  <h3 class="font-medium">
                    {href ? (
                      <a class="cactus-link" href={href} target="_blank" rel="noopener noreferrer">
                        {project.data.title}
                      </a>
                    ) : (
                      project.data.title
                    )}
                  </h3>
                  <p class="mt-1 text-sm">{project.data.description}</p>
                  <p class="mt-1 text-sm opacity-70">{project.data.technologies.join(" · ")}</p>
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    {
      clientProjects.length > 0 && (
        <section class="max-w-prose space-y-6">
          <h2 class="title text-xl">{copy.clientWorkTitle}</h2>
          <ul class="space-y-4">
            {clientProjects.map((project) => {
              const href = getProjectPrimaryLink(project);

              return (
                <li>
                  <h3 class="font-medium">
                    {href ? (
                      <a class="cactus-link" href={href} target="_blank" rel="noopener noreferrer">
                        {project.data.title}
                      </a>
                    ) : (
                      project.data.title
                    )}
                  </h3>
                  <p class="mt-1 text-sm">{project.data.description}</p>
                  <p class="mt-1 text-sm opacity-70">{project.data.technologies.join(" · ")}</p>
                </li>
              );
            })}
          </ul>
        </section>
      )
    }

    <section class="max-w-prose space-y-6">
      <h2 class="title text-xl">{copy.educationTitle}</h2>
      <div class="divide-textColor/20 divide-y divide-dashed">
        {
          education.map((entry, i) => (
            <article class:list={[i === 0 ? "pb-6" : "py-6"]}>
              <div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
                <div>
                  <h3 class="font-medium">{entry.data.degree}</h3>
                  <p class="text-accent text-sm">
                    {entry.data.institution}
                    {entry.data.field && ` · ${entry.data.field}`}
                  </p>
                </div>
                <p class="text-sm opacity-70">
                  <FormattedDate date={entry.data.startDate} dateTimeOptions={{ year: "numeric" }} />
                  {" — "}
                  {entry.data.endDate ? (
                    <FormattedDate date={entry.data.endDate} dateTimeOptions={{ year: "numeric" }} />
                  ) : (
                    copy.presentLabel
                  )}
                </p>
              </div>
              {entry.data.summary && <p class="mt-3 text-sm">{entry.data.summary}</p>}
            </article>
          ))
        }
      </div>
    </section>
  </div>
</PageLayout>
